# Copy to .env and fill in to run in live mode.
# With this unset, the pipeline runs in offline "mock" mode automatically —
# see agent/llm_client.py for why that's safe to demo without a key.
ANTHROPIC_API_KEY=

# Defaults to the local vuln-mart target; override to point at Juice Shop etc.
TARGET_URL=http://127.0.0.1:5001
