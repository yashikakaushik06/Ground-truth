{
  "target": "http://127.0.0.1:5001",
  "mode": "mock",
  "understanding": [
    {
      "endpoint": "/api/login",
      "purpose": "authenticate a user with username/password",
      "actors": "anonymous",
      "trust_boundary": "client-supplied fields should not be trusted for authz decisions",
      "invariant": "only correct username+password should authenticate"
    },
    {
      "endpoint": "/api/orders/<id>",
      "purpose": "fetch a single order by id, requires auth token",
      "actors": "authenticated owner",
      "trust_boundary": "client-supplied fields should not be trusted for authz decisions",
      "invariant": "a user should only ever be able to read their own orders"
    },
    {
      "endpoint": "/api/profile/update",
      "purpose": "update the caller's own profile fields",
      "actors": "authenticated self",
      "trust_boundary": "client-supplied fields should not be trusted for authz decisions",
      "invariant": "a user should only be able to modify their own non-privileged fields (never role)"
    },
    {
      "endpoint": "/api/internal/config",
      "purpose": "internal/debug configuration endpoint",
      "actors": "admin only",
      "trust_boundary": "client-supplied fields should not be trusted for authz decisions",
      "invariant": "internal/debug data must never be reachable without admin auth"
    },
    {
      "endpoint": "/api/export",
      "purpose": "export data in a given format",
      "actors": "any",
      "trust_boundary": "client-supplied fields should not be trusted for authz decisions",
      "invariant": "no strong invariant identified"
    }
  ],
  "hypotheses_tested": 5,
  "all_attempts": [
    {
      "target_endpoint": "/api/login",
      "verified": true,
      "claim": "SQL injection in /api/login allows authentication bypass without valid credentials.",
      "evidence": {
        "control": {
          "status": 401,
          "body": {
            "error": "invalid credentials"
          },
          "headers": {
            "Server": "Werkzeug/3.1.8 Python/3.13.5",
            "Date": "Fri, 03 Jul 2026 19:08:00 GMT",
            "Content-Type": "application/json",
            "Content-Length": "32",
            "Connection": "close"
          }
        },
        "treatment": {
          "status": 200,
          "body": {
            "id": 3,
            "role": "admin",
            "token": "tok-admin-003",
            "username": "admin"
          },
          "headers": {
            "Server": "Werkzeug/3.1.8 Python/3.13.5",
            "Date": "Fri, 03 Jul 2026 19:08:00 GMT",
            "Content-Type": "application/json",
            "Content-Length": "67",
            "Connection": "close"
          }
        }
      },
      "impact": "full account takeover of the first matching user via crafted username",
      "severity": "critical"
    },
    {
      "target_endpoint": "/api/orders/<id>",
      "verified": true,
      "claim": "IDOR on /api/orders/<id>: authenticated users can read any other user's order by id.",
