          "headers": {
            "Server": "Werkzeug/3.1.8 Python/3.13.5",
            "Date": "Fri, 03 Jul 2026 19:08:00 GMT",
            "Content-Type": "application/json",
            "Content-Length": "78",
            "Connection": "close"
          }
        }
      },
      "impact": "disclosure of other customers' order contents and totals",
      "severity": "high"
    },
